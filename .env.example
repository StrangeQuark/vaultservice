# App and server config
SPRING_APPLICATION_NAME=vaultservice
SERVER_PORT=6020
CORS_ALLOWED_ORIGINS=http://localhost:6080,http://localhost:8080,http://react-service
LOGGING_LEVEL=INFO

# DB Config
SPRING_DATASOURCE_URL=jdbc:postgresql://vault-db:5432/vaultservice
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vaultservice

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_DATABASE=postgresql
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Secret keys
# Generate this secret key with the following linux shell command: head /dev/urandom | tr -dc A-F0-9 | head -c32
ENCRYPTION_KEY=change-me
CICD_TOKEN=change-me # Integration line: Auth
ACCESS_SECRET_KEY=change-me # Integration line: Auth
SERVICE_SECRET_VAULT=change-me # Integration line: Auth
